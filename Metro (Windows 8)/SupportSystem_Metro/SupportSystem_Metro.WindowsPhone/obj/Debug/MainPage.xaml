<Page
    x:Class="SupportSystem_Metro.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:SupportSystem_Metro"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Button x:ConnectionId='1' x:Uid="Finish" HorizontalAlignment="Left" Margin="10" VerticalAlignment="Top" x:Name="Finish"                      FontSize="30"/>
        <ScrollViewer Grid.Row="2">
            <StackPanel Grid.Row="1" Visibility="Visible" VerticalAlignment="Center">
                <ToggleSwitch x:ConnectionId='2' x:Name="Purpose"                           x:Uid="PC_Purpose" OffContent="To work" OnContent="To home" IsOn="True" HorizontalAlignment="Center" VerticalAlignment="Top" Height="Auto" Width="Auto" Margin="10,0,0,0" FontSize="20"/>
                <ToggleSwitch x:ConnectionId='3' x:Name="Mobile"                          x:Uid="PC_Modility" OffContent="No" OnContent="Yes" IsOn="False" Height="Auto" Width="Auto" HorizontalAlignment="Center" VerticalAlignment="Top" Margin="10,0,0,0" FontSize="20"/>
                <ToggleSwitch x:ConnectionId='4' x:Name="pro"                       x:Uid="PC_Pro" OffContent="No" OnContent="Yes" IsOn="False" Height="Auto" Width="Auto" HorizontalAlignment="Center" VerticalAlignment="Top" Margin="10,0,0,0" FontSize="20"/>
                <ToggleSwitch x:ConnectionId='5' x:Name="bigROM"                          x:Uid="PC_bigROM" OffContent="No" OnContent="Yes" IsOn="False" Height="Auto" Width="Auto" HorizontalAlignment="Center" VerticalAlignment="Top" Margin="10,0,0,0" FontSize="20"/>
                <ToggleSwitch x:ConnectionId='6' x:Name="Sync"                        x:Uid="PC_Sync" OffContent="No" OnContent="Yes" IsOn="False" Height="Auto" Width="Auto" HorizontalAlignment="Center" VerticalAlignment="Top" Margin="10,0,0,0" FontSize="20"/>
                <ToggleSwitch x:ConnectionId='7' x:Name="Phone_sync"                              x:Uid="PC_phoneSync" OffContent="iPhone" OnContent="Android" IsOn="True" Height="Auto" Width="Auto" HorizontalAlignment="Center" VerticalAlignment="Top" Margin="10,0,0,0" IsEnabled="True" FontSize="20"/>
                <ToggleSwitch x:ConnectionId='8' x:Name="Assembly"                            x:Uid="PC_Assembly" OffContent="No" OnContent="Yes" IsOn="False" Height="Auto" Width="Auto" HorizontalAlignment="Center" VerticalAlignment="Top" Margin="10,0,0,0" FontSize="20"/>
                <ToggleSwitch x:ConnectionId='9' x:Name="Ecosystem"                             x:Uid="PC_Ecosystem" OffContent="No" OnContent="Yes" IsOn="False" Height="Auto" Width="Auto" HorizontalAlignment="Center" VerticalAlignment="Top" Margin="10,0,0,0" FontSize="20"/>
                <ToggleSwitch x:ConnectionId='10' x:Name="Games"                         x:Uid="PC_Game" OffContent="No" OnContent="Yes" IsOn="False" Height="Auto" Width="Auto" HorizontalAlignment="Center" VerticalAlignment="Top" Margin="10,0,0,0" FontSize="20"/>
            </StackPanel>
        </ScrollViewer>
        <Grid Grid.Row="1">
            <Grid>
                <Image x:Name="Image_PC" Source="/Assets/Surface.png" />
            </Grid>
        </Grid>
        <StackPanel Grid.Row="3">
            <TextBlock x:Name="Res" FontSize="30"/>
        </StackPanel>
    </Grid>
</Page>

